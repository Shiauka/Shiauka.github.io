---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { episodes } from '@/data/episodes'
import { getCollection } from 'astro:content'

const allArticles = await getCollection('articles', ({ data }) => !data.draft && data.episode != null)
const articlesByEp: Record<number, typeof allArticles> = {}
for (const article of allArticles) {
  const ep = article.data.episode!
  if (!articlesByEp[ep]) articlesByEp[ep] = []
  articlesByEp[ep].push(article)
}
for (const ep of Object.values(articlesByEp)) {
  ep.sort((a, b) => a.data.pubDate.getTime() - b.data.pubDate.getTime())
}

const uploaded   = episodes.filter(ep =>  ep.youtubeId).sort((a, b) => b.ep - a.ep)
const unuploaded = episodes.filter(ep => !ep.youtubeId).sort((a, b) => a.ep - b.ep)
const nextEp     = unuploaded[0]
const futureEps  = unuploaded.slice(1)
const sorted     = [...(nextEp ? [nextEp] : []), ...uploaded, ...futureEps]
---

<BaseLayout
  title="播客"
  description="一個工程師的財務自白——全集數列表。從資產配置理念到實際操作，每集聚焦一個主題。"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

    <!-- 標題 -->
    <div class="mb-10">
      <p class="text-brand font-medium text-sm uppercase tracking-wide mb-2">Podcast</p>
      <h1 class="text-3xl font-bold mb-3">一個工程師的財務自白</h1>
      <p class="text-gray-600 max-w-2xl">
        把複雜的投資邏輯拆解成一集一集的故事。每集聚焦一個主題，
        從理念到工具，從策略到紀律，帶你建立自己的投資系統。
      </p>
    </div>

    <!-- 集數列表 -->
    <div class="space-y-3">
      {sorted.map(ep => {
        const isNext   = nextEp && ep.ep === nextEp.ep
        const epArts   = articlesByEp[ep.ep] ?? []
        const hasYt    = !!ep.youtubeId
        return (
          <div class={`p-5 rounded-xl border transition-all ${
            hasYt
              ? 'border-gray-200 hover:border-brand hover:shadow-md'
              : isNext
                ? 'border-brand/40 bg-brand/5'
                : 'border-dashed border-gray-200 opacity-50'
          }`}>
            <div class="flex items-start gap-4">
              <!-- EP 編號 -->
              <div class="shrink-0 w-12 h-12 rounded-lg bg-brand/10 flex items-center justify-center">
                <span class="text-brand font-bold text-sm">{String(ep.ep).padStart(2, '0')}</span>
              </div>

              <!-- 內容 -->
              <div class="flex-1 min-w-0">
                <!-- 標題 + 狀態 -->
                <div class="flex items-start justify-between gap-3 mb-1">
                  <h2 class="font-semibold leading-snug">{ep.title}</h2>
                  {hasYt && (
                    <a
                      href={`https://www.youtube.com/watch?v=${ep.youtubeId}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="shrink-0 text-xs font-medium text-red-600 border border-red-200 rounded px-2 py-0.5 hover:bg-red-50 transition-colors whitespace-nowrap"
                    >
                      ▶ 觀看
                    </a>
                  )}
                  {!hasYt && isNext && (
                    <span class="shrink-0 text-xs text-brand font-medium whitespace-nowrap">下一集</span>
                  )}
                  {!hasYt && !isNext && (
                    <span class="shrink-0 text-xs text-gray-400 whitespace-nowrap">即將上架</span>
                  )}
                </div>

                <!-- 簡介 -->
                <p class="text-sm text-gray-500">{ep.desc}</p>

                <!-- 對應文章 -->
                {epArts.length > 0 && (
                  <div class="mt-2.5 flex flex-wrap gap-x-4 gap-y-1">
                    {epArts.map(article => (
                      <a
                        href={`/articles/${article.slug}`}
                        class="text-xs text-brand hover:underline"
                      >
                        📖 {article.data.title}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        )
      })}
    </div>

  </div>
</BaseLayout>
