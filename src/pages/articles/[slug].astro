---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Disclaimer from '@/components/Disclaimer.astro'
import { episodes } from '@/data/episodes'

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft)
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content } = await article.render()

const disclaimerType = article.data.tags.some(t =>
  ['美國遺產稅', '稅務風險', '法律'].includes(t)
) ? 'legal' : article.data.tags.some(t =>
  ['稅務', '開戶', '複委託'].includes(t)
) ? 'tax' : 'general'

const matchedEp = article.data.episode
  ? episodes.find(e => e.ep === article.data.episode)
  : null
const youtubeUrl = matchedEp?.youtubeId
  ? `https://www.youtube.com/watch?v=${matchedEp.youtubeId}`
  : null
---

<BaseLayout title={article.data.title} description={article.data.description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">

    <!-- 麵包屑 -->
    <nav class="text-sm text-gray-500 mb-8">
      <a href="/" class="hover:text-brand transition-colors">首頁</a>
      <span class="mx-2">/</span>
      <a href="/articles" class="hover:text-brand transition-colors">文章</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800">{article.data.title}</span>
    </nav>

    <!-- 標籤與集數 -->
    <div class="flex flex-wrap items-center gap-2 mb-4">
      {article.data.episode && (
        <span class="bg-brand/10 text-brand text-xs font-semibold px-2.5 py-1 rounded-full">
          EP{String(article.data.episode).padStart(2, '0')} 對應文章
        </span>
      )}
      {youtubeUrl && (
        <a
          href={youtubeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-red-50 text-red-600 text-xs font-semibold px-2.5 py-1 rounded-full hover:bg-red-100 transition-colors inline-flex items-center gap-1"
        >
          ▶ 收聽播客
        </a>
      )}
      {article.data.tags.map(tag => (
        <span class="bg-gray-100 text-gray-600 text-xs px-2.5 py-1 rounded-full">#{tag}</span>
      ))}
    </div>

    <!-- 標題 -->
    <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-4">{article.data.title}</h1>
    <p class="text-gray-500 text-sm mb-10">
      {article.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
    </p>

    <!-- 正文 -->
    <div class="article-body">
      <Content />
    </div>

    <!-- 免責聲明 -->
    <Disclaimer type={disclaimerType} />

    <!-- 上一篇 / 下一篇（未來擴充用，暫留空間） -->
    <div class="mt-10 pt-8 border-t border-gray-100">
      <a href="/articles" class="text-brand hover:text-brand-dark font-medium transition-colors">
        ← 回到文章列表
      </a>
    </div>

  </article>
</BaseLayout>
