---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
---

<BaseLayout
  title="文章"
  description="祿哥的投資深度文章——每篇對應播客集數，有圖表、有數字、有完整推理。"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">

    <div class="mb-10">
      <p class="text-brand font-medium text-sm uppercase tracking-wide mb-2">Articles</p>
      <h1 class="text-3xl font-bold mb-3">文章</h1>
      <p class="text-gray-600 max-w-2xl">
        每篇文章對應一集播客，比音頻更深入——有圖表、有數字、有完整推理。
      </p>
    </div>

    <div class="space-y-4">
      {articles.map(article => (
        <a
          href={`/articles/${article.slug}`}
          class="flex items-start gap-4 p-5 rounded-xl border border-gray-200 hover:border-brand hover:shadow-md transition-all group"
        >
          <div class="shrink-0 mt-0.5">
            {article.data.episode ? (
              <span class="inline-block text-xs font-semibold bg-brand/10 text-brand px-2.5 py-1 rounded-full whitespace-nowrap">
                EP{String(article.data.episode).padStart(2, '0')}
              </span>
            ) : (
              <span class="inline-block text-xs font-semibold bg-gray-100 text-gray-500 px-2.5 py-1 rounded-full">
                深度
              </span>
            )}
          </div>
          <div class="flex-1 min-w-0">
            <h2 class="font-semibold text-gray-900 group-hover:text-brand transition-colors leading-snug mb-1">
              {article.data.title}
            </h2>
            <p class="text-sm text-gray-500 line-clamp-2">{article.data.description}</p>
            <div class="flex flex-wrap gap-1.5 mt-2">
              {article.data.tags.slice(0, 3).map(tag => (
                <span class="text-xs text-gray-400">#{tag}</span>
              ))}
            </div>
          </div>
          <span class="shrink-0 text-gray-400 group-hover:text-brand transition-colors mt-1">→</span>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
