---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout title="找不到頁面">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-32 text-center">
    <p class="text-6xl font-bold text-brand mb-4">404</p>
    <h1 class="text-2xl font-bold mb-2">找不到這個頁面</h1>
    <p class="text-gray-500 mb-8">這筆投資可能已經下架，或網址打錯了。</p>
    <a href="/" class="bg-brand hover:bg-brand-dark text-white font-semibold px-6 py-3 rounded-lg transition-colors">
      回到首頁
    </a>
  </div>
</BaseLayout>
